# ── 运行模式 ──────────────────────────────────────────────────
# demo = 离线 Demo 模式（默认），无需任何 API 配置
# live = 在线 Live 模式，需配置下方 LLM 相关变量
LLM_MODE=demo

# ── Live Mode 必填 ────────────────────────────────────────────
# 仅在 LLM_MODE=live 时需要以下配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── Live Mode 可选 ────────────────────────────────────────────
# 自定义 OpenAI 兼容接口地址（如 Ollama、第三方代理等）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
